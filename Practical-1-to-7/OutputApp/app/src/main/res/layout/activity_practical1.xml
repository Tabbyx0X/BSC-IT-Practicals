<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_practical1.xml – Practical 1: Resources Demo
    Demonstrates:
      • String resource  → android:text="@string/..."
      • Color resource   → android:background="@color/..."
      • Drawable resource → android:src="@drawable/..."
      • Dimension resource → android:padding="@dimen/..."
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Large title required by spec -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Practical 1 Output"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- ── String resource ────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="String Resource"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/p1_greeting"
            android:textAppearance="?attr/textAppearanceBody1"
            android:paddingBottom="20dp" />

        <!-- ── Color resource ─────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Color Resource"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <!-- A box whose background color comes from @color/accent -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/accent"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text='Background color → @color/accent (#03DAC5)'
            android:textAppearance="?attr/textAppearanceCaption"
            android:paddingBottom="20dp" />

        <!-- ── Drawable resource ──────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Drawable Resource"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <!-- Vector drawable from res/drawable/ic_sample.xml -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_sample"
            android:contentDescription="@string/p1_image_desc"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text='Image from → @drawable/ic_sample'
            android:textAppearance="?attr/textAppearanceCaption"
            android:paddingBottom="20dp" />

        <!-- ── Dimension resource ─────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dimension Resource"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <!-- Padding applied via @dimen/p1_padding -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_variant"
            android:padding="@dimen/p1_padding"
            android:text="@string/p1_dimension_demo"
            android:textAppearance="?attr/textAppearanceBody1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text='Padding → @dimen/p1_padding (24dp)'
            android:textAppearance="?attr/textAppearanceCaption"
            android:paddingTop="4dp" />

    </LinearLayout>
</ScrollView>
