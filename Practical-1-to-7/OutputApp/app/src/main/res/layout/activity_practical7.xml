<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_practical7.xml – Practical 7: Services, Notifications & Broadcast Demo
    Contains:
      • Status TextView showing events as they happen
      • Buttons for: Send Broadcast, Send Notification, Start Service, Stop Service
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Large title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Practical 7 Output"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Status log -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status Log:"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvStatus7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:background="@color/surface_variant"
            android:padding="10dp"
            android:fontFamily="monospace"
            android:textAppearance="?attr/textAppearanceBody2"
            android:text="(events will appear here)"
            android:layout_marginBottom="24dp" />

        <!-- ── Broadcast Receiver ─────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local Broadcast Receiver"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btnSendBroadcast"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send Custom Broadcast"
            android:layout_marginBottom="20dp" />

        <!-- ── Notification ────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btnSendNotification"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Send Notification"
            android:layout_marginBottom="20dp" />

        <!-- ── Service ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Background Service"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/btnStartService"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Service"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnStopService"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop Service" />

    </LinearLayout>
</ScrollView>
