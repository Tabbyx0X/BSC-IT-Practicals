<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_practical2.xml – Practical 2: Activities & Fragments Demo
    Shows:
      • Lifecycle log TextView
      • FragmentContainerView where FragmentA / FragmentB are swapped
      • Two buttons: Switch Fragment and Open Second Activity
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <!-- Large title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Practical 2 Output"
        android:textAppearance="?attr/textAppearanceHeadline5"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <!-- Lifecycle log section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Activity Lifecycle Log:"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/primary"
        android:paddingBottom="4dp" />

    <!-- Scrollable container for the lifecycle log -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@color/surface_variant"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvLifecycleLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="@color/on_surface" />
    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Fragment container (FragmentA shown by default) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fragment Container:"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/primary"
        android:paddingBottom="4dp" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@color/surface_variant" />

    <!-- Buttons -->
    <Button
        android:id="@+id/btnSwitchFragment"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Switch Fragment (A ↔ B)" />

    <Button
        android:id="@+id/btnOpenSecondActivity"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Open Second Activity" />

</LinearLayout>
