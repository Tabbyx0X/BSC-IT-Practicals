<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_practical4.xml – Practical 4: UI Elements Demo
    Demonstrates:
      • Material AppBar / Toolbar
      • TextView, Button, EditText, CheckBox, Switch
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Material Toolbar / AppBar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar4"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:elevation="4dp" />

    <!-- Scrollable content below the toolbar -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <!-- Large title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Practical 4 Output"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:gravity="center"
                android:paddingBottom="24dp" />

            <!-- TextView widget -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Widget: TextView"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/primary"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is a TextView – used to display static or dynamic text."
                android:textAppearance="?attr/textAppearanceBody1"
                android:paddingBottom="20dp" />

            <!-- Button widget -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Widget: Button"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/primary"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btnClickMe"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Click Me!"
                android:layout_marginBottom="20dp" />

            <!-- EditText widget -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Widget: EditText"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/primary"
                android:paddingBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Type something here…"
                android:layout_marginBottom="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnReadInput"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read Input"
                android:layout_marginBottom="20dp" />

            <!-- CheckBox widget -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Widget: CheckBox"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/primary"
                android:paddingBottom="4dp" />

            <CheckBox
                android:id="@+id/cbCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I agree to the terms"
                android:layout_marginBottom="20dp" />

            <!-- Switch widget -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Widget: Switch"
                android:textAppearance="?attr/textAppearanceSubtitle1"
                android:textColor="@color/primary"
                android:paddingBottom="4dp" />

            <Switch
                android:id="@+id/swToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable feature" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
