<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_practical3.xml – Practical 3: Layouts Demo

    Demonstrates three layout types in one scrollable screen:
      1. LinearLayout  – views stacked vertically
      2. RelativeLayout – views positioned relative to each other
      3. ConstraintLayout – views constrained to parent edges / siblings
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Page title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Practical 3 Output"
            android:textAppearance="?attr/textAppearanceHeadline5"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Section 1: LinearLayout                                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 · LinearLayout (vertical)"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface_variant"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Row 1 – aligned top to bottom"
                android:background="@color/accent_light"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Row 2 – each child stacked below"
                android:background="@color/accent_light"
                android:padding="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Row 3 – the previous one"
                android:background="@color/accent_light"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Section 2: RelativeLayout                                      -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 · RelativeLayout"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/surface_variant"
            android:padding="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvRelTop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOP-LEFT"
                android:background="@color/accent_light"
                android:padding="6dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true" />

            <TextView
                android:id="@+id/tvRelCenter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CENTER"
                android:background="@color/accent_light"
                android:padding="6dp"
                android:layout_centerInParent="true" />

            <TextView
                android:id="@+id/tvRelBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BOTTOM-RIGHT"
                android:background="@color/accent_light"
                android:padding="6dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true" />
        </RelativeLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Section 3: ConstraintLayout                                    -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3 · ConstraintLayout"
            android:textAppearance="?attr/textAppearanceSubtitle1"
            android:textColor="@color/primary"
            android:paddingBottom="8dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@color/surface_variant"
            android:padding="8dp">

            <TextView
                android:id="@+id/tvConsA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Constrained\nto START"
                android:background="@color/accent_light"
                android:padding="6dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvConsB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Constrained\nto END"
                android:background="@color/accent_light"
                android:padding="6dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:id="@+id/tvConsC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Horizontally\nCentered"
                android:background="@color/accent_light"
                android:padding="6dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>
</ScrollView>
