<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CalculatorApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="android:windowBackground">@color/calc_background</item>
    </style>

    <!-- Base calculator button -->
    <style name="CalcButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/btn_digit_text</item>
        <item name="backgroundTint">@color/btn_digit_bg</item>
        <item name="cornerRadius">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Function buttons (C, +/−, ⌫) -->
    <style name="CalcButton.Function">
        <item name="android:textColor">@color/btn_function_text</item>
        <item name="backgroundTint">@color/btn_function_bg</item>
    </style>

    <!-- Operator buttons (+, −, ×, ÷) -->
    <style name="CalcButton.Operator">
        <item name="android:textColor">@color/btn_operator_text</item>
        <item name="backgroundTint">@color/btn_operator_bg</item>
    </style>

    <!-- Equals button -->
    <style name="CalcButton.Equals">
        <item name="android:textColor">@color/btn_equals_text</item>
        <item name="backgroundTint">@color/btn_equals_bg</item>
    </style>
</resources>
