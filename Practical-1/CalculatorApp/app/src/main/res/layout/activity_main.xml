<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calc_background">

    <!-- Display -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="24dp"
        android:background="@color/display_background"
        android:ellipsize="start"
        android:gravity="end|center_vertical"
        android:maxLines="1"
        android:minHeight="80dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="0"
        android:textColor="@color/display_text"
        android:textSize="40sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Button grid -->
    <GridLayout
        android:id="@+id/buttonGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:columnCount="4"
        android:rowCount="5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDisplay">

        <!-- Row 1: C  +/-  ⌫  ÷ -->
        <Button
            android:id="@+id/btnClear"
            style="@style/CalcButton.Function"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_clear" />

        <Button
            android:id="@+id/btnToggleSign"
            style="@style/CalcButton.Function"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_toggle_sign" />

        <Button
            android:id="@+id/btnBackspace"
            style="@style/CalcButton.Function"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_backspace" />

        <Button
            android:id="@+id/btnDiv"
            style="@style/CalcButton.Operator"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_div" />

        <!-- Row 2: 7  8  9  × -->
        <Button
            android:id="@+id/btn7"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="7" />

        <Button
            android:id="@+id/btn8"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="8" />

        <Button
            android:id="@+id/btn9"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="9" />

        <Button
            android:id="@+id/btnMul"
            style="@style/CalcButton.Operator"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_mul" />

        <!-- Row 3: 4  5  6  − -->
        <Button
            android:id="@+id/btn4"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="4" />

        <Button
            android:id="@+id/btn5"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="5" />

        <Button
            android:id="@+id/btn6"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="6" />

        <Button
            android:id="@+id/btnSub"
            style="@style/CalcButton.Operator"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_sub" />

        <!-- Row 4: 1  2  3  + -->
        <Button
            android:id="@+id/btn1"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="1" />

        <Button
            android:id="@+id/btn2"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="2" />

        <Button
            android:id="@+id/btn3"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="3" />

        <Button
            android:id="@+id/btnAdd"
            style="@style/CalcButton.Operator"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_add" />

        <!-- Row 5: 0  0  .  = -->
        <Button
            android:id="@+id/btn0"
            style="@style/CalcButton"
            android:layout_columnSpan="2"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="0" />

        <Button
            android:id="@+id/btnDot"
            style="@style/CalcButton"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_dot" />

        <Button
            android:id="@+id/btnEquals"
            style="@style/CalcButton.Equals"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:text="@string/btn_equals" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
